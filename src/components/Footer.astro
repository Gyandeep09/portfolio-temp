---
---
<footer class="w-full border-t border-gray-100 dark:border-slate-800/60 mt-16 relative overflow-hidden">

  <div class="absolute inset-x-0 top-0 h-10 overflow-hidden pointer-events-none select-none" aria-hidden="true">
    <div class="marquee-row animate-marquee-ltr text-[10px] font-mono opacity-[0.15] dark:opacity-[0.06] whitespace-nowrap text-gray-900 dark:text-white">
      {Array(8).fill('Full Stack Dev · React · TypeScript · Node.js · Astro · PostgreSQL · TailwindCSS · Framer Motion · ').join('')}
    </div>
  </div>
  <div class="absolute inset-x-0 bottom-10 h-10 overflow-hidden pointer-events-none select-none" aria-hidden="true">
    <div class="marquee-row animate-marquee-rtl text-[10px] font-mono opacity-[0.15] dark:opacity-[0.06] whitespace-nowrap text-gray-900 dark:text-white">
      {Array(8).fill('Performance · Accessibility · Open Source · UI / UX · Mobile First · Clean Code · ').join('')}
    </div>
  </div>

  <div id="contact" class="relative z-10 max-w-3xl mx-auto px-6 py-12 flex flex-col items-center gap-6 text-center">

    <p class="text-xs uppercase tracking-widest text-gray-400 dark:text-gray-600 font-mono">
      Connect With Me
    </p>

    <div id="social-anchor-bottom" class="hidden md:flex items-center justify-center w-[210px] h-[24px]"></div>

    <div class="flex md:hidden items-center justify-center gap-6 mt-2 mb-4 text-gray-400 dark:text-gray-500">
      <a href="#" aria-label="GitHub" class="hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0c-2.4-1.6-3.5-1.3-3.5-1.3a4.2 4.2 0 0 0-.1 3.2 4.6 4.6 0 0 0-1.3 3.2c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21" /></svg>
      </a>
      <a href="#" aria-label="LinkedIn" class="hover:text-blue-500 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4m0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2h-12a2 2 0 0 1-2-2z" /><path d="M8 11l0 5" /><path d="M8 8l0 .01" /><path d="M12 16l0-5" /><path d="M16 16v-3a2 2 0 0 0-4 0" /></svg>
      </a>
      <a href="#" aria-label="Instagram" class="hover:text-pink-500 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4m0 4a4 4 0 0 1 4-4h8a4 4 0 0 1 4 4v8a4 4 0 0 1-4 4h-8a4 4 0 0 1-4-4z" /><path d="M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0-6 0" /><path d="M16.5 7.5l0 .01" /></svg>
      </a>
      <a href="https://wa.me/919864874820" aria-label="WhatsApp" class="hover:text-green-500 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9l-5.05.9" /><path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1a5 5 0 0 0 5 5h1a.5.5 0 0 0 0-1h-1a.5.5 0 0 0 0 1" /></svg>
      </a>
    </div>

    <div class="w-full flex flex-col sm:flex-row items-center justify-between gap-2 pt-6 border-t border-gray-100 dark:border-slate-800 pb-24 sm:pb-6">
      <p class="text-xs text-gray-400 dark:text-gray-600">
        Portfolio Owner ⚡ © {new Date().getFullYear()}
      </p>
      <a href="#" aria-label="Back to top"
         class="flex items-center gap-1 text-xs text-gray-400 dark:text-gray-600 hover:text-gray-700 dark:hover:text-gray-300 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 19V5"/><path d="M5 12l7-7 7 7"/>
        </svg>
        back to top
      </a>
    </div>
  </div>

</footer>

<style>
  @keyframes marquee-ltr {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @keyframes marquee-rtl {
    0%   { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }
  .animate-marquee-ltr { animation: marquee-ltr 30s linear infinite; }
  .animate-marquee-rtl { animation: marquee-rtl 34s linear infinite; }
</style>
