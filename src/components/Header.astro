---
import ThemeToggle from './ThemeToggle';
import MusicPlayer from './MusicPlayer';
import LiveClock from './LiveClock';
---

<header class="w-full fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-white/70 dark:bg-[#0d1117]/70 border-b border-gray-100/50 dark:border-slate-800/30">
  <nav id="home" class="flex justify-between items-center px-4 sm:px-8 py-3 w-full max-w-[1600px] mx-auto">

    <div class="flex items-center gap-2 sm:gap-5">
      <MusicPlayer client:load />
      <div class="hidden sm:block w-px h-5 bg-gray-200 dark:bg-slate-700/60" />
      <div class="hidden xs:block"><LiveClock client:load /></div>
      <div class="hidden sm:block w-px h-5 bg-gray-200 dark:bg-slate-700/60" />
      <ThemeToggle client:load />
    </div>

    <div class="flex items-center gap-6 sm:gap-8">

      <nav class="hidden md:flex items-center gap-6 lg:gap-8" aria-label="Primary navigation">
        <a href="/#home"       class="nav-link" data-section="home">Home</a>
        <a href="/#about"      class="nav-link" data-section="about">About</a>
        <a href="/experience"  class="nav-link" data-section="experience">Experience</a>
        <a href="/projects"    class="nav-link" data-section="projects">Projects</a>
        <a href="/#principles" class="nav-link" data-section="principles">Principles</a>
      </nav>

      <div class="hidden md:block w-px h-5 bg-gray-200 dark:bg-slate-700/60" />

      <div id="social-anchor-top" class="hidden md:block w-[160px] h-[40px]"></div>

      <div class="flex md:hidden items-center gap-3 sm:gap-4 text-gray-500 dark:text-gray-400">
        <a href="#" aria-label="GitHub" class="hover:text-gray-900 dark:hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0c-2.4-1.6-3.5-1.3-3.5-1.3a4.2 4.2 0 0 0-.1 3.2 4.6 4.6 0 0 0-1.3 3.2c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21" /></svg>
        </a>
        <a href="#" aria-label="LinkedIn" class="hover:text-blue-500 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4m0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2h-12a2 2 0 0 1-2-2z" /><path d="M8 11l0 5" /><path d="M8 8l0 .01" /><path d="M12 16l0-5" /><path d="M16 16v-3a2 2 0 0 0-4 0" /></svg>
        </a>
        <a href="#" aria-label="Instagram" class="hover:text-pink-500 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4m0 4a4 4 0 0 1 4-4h8a4 4 0 0 1 4 4v8a4 4 0 0 1-4 4h-8a4 4 0 0 1-4-4z" /><path d="M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0-6 0" /><path d="M16.5 7.5l0 .01" /></svg>
        </a>
        <a href="https://wa.me/919864874820" aria-label="WhatsApp" class="hover:text-green-500 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9l-5.05.9" /><path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1a5 5 0 0 0 5 5h1a.5.5 0 0 0 0-1h-1a.5.5 0 0 0 0 1" /></svg>
        </a>
      </div>
    </div>

  </nav>
</header>

<script is:inline>
  (function() {
    var links = document.querySelectorAll('.nav-link');
    var sections = ['home','about','experience','projects','principles'];

    function setActive(id) {
      links.forEach(function(l) {
        var isActive = l.getAttribute('data-section') === id;
        l.classList.toggle('nav-link-active', isActive);
      });
    }

    var path = window.location.pathname;
    if (path.includes('/experience')) {
      setActive('experience');
      return; // Stop here, don't use scroll observer
    }
    if (path.includes('/projects')) {
      setActive('projects');
      return; // Stop here, don't use scroll observer
    }

    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) setActive(e.target.id);
      });
    }, { threshold: 0.35 });

    sections.forEach(function(id) {
      var el = document.getElementById(id) || document.querySelector('[id="'+id+'"]');
      if (el) io.observe(el);
    });
  })();
</script>

<style>
  .nav-link {
    font-family: 'Inter', ui-monospace, monospace;
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #9ca3af;
    text-decoration: none;
    transition: color 0.2s ease, font-weight 0.15s ease;
    position: relative;
    white-space: nowrap;
  }

  :global(html:not(.dark)) .nav-link {
    color: #6b7280;
  }

  .nav-link:hover {
    color: #111827;
  }

  :global(html.dark) .nav-link:hover {
    color: #f9fafb;
  }

  /* Active section — bold + white/black glow */
  .nav-link-active {
    color: #111827 !important;
    font-weight: 700;
  }

  :global(html.dark) .nav-link-active {
    color: #ffffff !important;
    text-shadow: 0 0 20px rgba(255,255,255,0.35);
  }
</style>
