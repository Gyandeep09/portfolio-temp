---
import Layout from '../../layouts/Layout.astro';
import { PROJECTS } from '../../data/projects';
import StackPill from '../../components/StackPill';

export const prerender = true;

const coreProjects    = PROJECTS.filter(p => p.category === 'core');
const midcoreProjects = PROJECTS.filter(p => p.category === 'midcore');
const casualProjects  = PROJECTS.filter(p => p.category === 'casual');
---

<Layout title="All Projects | Portfolio Owner" description="A complete list of projects by Portfolio Owner — core builds, mid-tier systems, and casual experiments.">
  <div class="max-w-3xl mx-auto px-6 py-24 min-h-screen">

    <a href="/" class="inline-flex items-center gap-2 text-[10px] font-mono uppercase tracking-widest text-gray-400 dark:text-gray-600 hover:text-gray-900 dark:hover:text-white transition-colors mb-14 group">
      <svg class="w-3 h-3 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      Back to Home
    </a>

    <div class="mb-16">
      <p class="text-[10px] font-mono uppercase tracking-[0.3em] text-gray-400 dark:text-gray-600 mb-3">/projects</p>
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 dark:text-white tracking-tight">Selected Work</h1>
      <p class="mt-3 text-sm text-gray-500 dark:text-gray-500 max-w-md leading-relaxed">
        Architecture-first builds — from production systems to experimental playgrounds.
      </p>
    </div>

    <section class="mb-16">
      <p class="text-[10px] font-mono uppercase tracking-[0.25em] text-gray-400 dark:text-gray-600 mb-5 pb-3 border-b border-gray-100 dark:border-zinc-800">Core / Production</p>
      <div>
        {coreProjects.map(proj => (
          <a href={`/projects/${proj.slug}`}
            class="group flex items-start justify-between gap-4 py-5 border-b border-gray-100 dark:border-zinc-800/60 hover:border-gray-300 dark:hover:border-zinc-600 transition-colors duration-200">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2.5 mb-1">
                <h2 class="text-sm font-bold text-gray-900 dark:text-white group-hover:text-blue-500 dark:group-hover:text-blue-400 transition-colors truncate">
                  {proj.title}
                </h2>
                <span class="shrink-0 px-2 py-0.5 rounded-full border border-gray-200 dark:border-zinc-700 text-[9px] font-mono uppercase tracking-wider text-gray-500 dark:text-gray-500 bg-transparent hidden sm:inline-flex">
                  {proj.tag}
                </span>
              </div>
              <p class="text-xs text-gray-500 dark:text-gray-500 line-clamp-1 mb-2">{proj.desc}</p>
              <div class="flex flex-wrap gap-1.5">
                {proj.stack.slice(0, 4).map((s: string) => (
                  <StackPill tech={s} />
                ))}
                {proj.stack.length > 4 && <span class="text-[9px] font-mono text-gray-400">+{proj.stack.length - 4}</span>}
              </div>
            </div>
            <svg class="shrink-0 w-3.5 h-3.5 text-gray-300 dark:text-gray-700 group-hover:text-blue-500 group-hover:translate-x-0.5 transition-all mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </a>
        ))}
      </div>
    </section>

    <section class="mb-16">
      <p class="text-[10px] font-mono uppercase tracking-[0.25em] text-gray-400 dark:text-gray-600 mb-5 pb-3 border-b border-gray-100 dark:border-zinc-800">Mid-Core / Systems</p>
      <div>
        {midcoreProjects.map(proj => (
          <a href={`/projects/${proj.slug}`}
            class="group flex items-start justify-between gap-4 py-4 border-b border-gray-100 dark:border-zinc-800/40 hover:border-gray-300 dark:hover:border-zinc-600 transition-colors duration-200">
            <div class="flex-1 min-w-0">
              <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 group-hover:text-blue-500 dark:group-hover:text-blue-400 transition-colors mb-0.5 truncate">
                {proj.title}
              </h2>
              <p class="text-[11px] font-mono text-gray-400 dark:text-gray-600">{proj.type}</p>
            </div>
            <div class="shrink-0 flex items-center gap-2">
              <div class="hidden sm:flex gap-1.5">
                {proj.stack.slice(0, 3).map((s: string) => (
                  <StackPill tech={s} />
                ))}
              </div>
              <svg class="w-3 h-3 text-gray-300 dark:text-gray-700 group-hover:text-blue-500 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section>
      <p class="text-[10px] font-mono uppercase tracking-[0.25em] text-gray-400 dark:text-gray-600 mb-5 pb-3 border-b border-gray-100 dark:border-zinc-800">Casual / Experiments</p>
      <div>
        {casualProjects.map(proj => (
          <a href={`/projects/${proj.slug}`}
            class="group flex items-center justify-between gap-4 py-3.5 border-b border-gray-100 dark:border-zinc-800/30 hover:border-gray-200 dark:hover:border-zinc-700 transition-colors duration-200">
            <h2 class="text-sm text-gray-600 dark:text-gray-400 group-hover:text-gray-900 dark:group-hover:text-white transition-colors truncate">{proj.title}</h2>
            <div class="shrink-0 flex items-center gap-2">
              <span class="text-[9px] font-mono text-gray-300 dark:text-gray-700 hidden sm:block">{proj.type}</span>
              <svg class="w-3 h-3 text-gray-300 dark:text-gray-700 group-hover:text-gray-500 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </section>

  </div>
</Layout>
