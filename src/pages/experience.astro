---
import Layout from '../layouts/Layout.astro';
import { EXPERIENCES } from '../data/experience';

export const prerender = true;
---

<Layout title="All Engagements | Portfolio Owner" description="A complete list of professional engagements and specialized training by Portfolio Owner.">
  <div class="max-w-2xl mx-auto px-6 py-24 min-h-screen">

    <a href="/" class="inline-flex items-center gap-2 text-[10px] font-mono uppercase tracking-widest text-gray-400 hover:text-blue-500 dark:hover:text-blue-400 transition-colors mb-14 group">
      <svg class="w-3 h-3 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      Back to Home
    </a>

    <div class="mb-16">
      <p class="text-[10px] font-mono uppercase tracking-[0.3em] text-blue-500 dark:text-blue-400 mb-3">/experience</p>
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 dark:text-white tracking-tight">Engagements</h1>
      <p class="mt-3 text-sm text-gray-500 dark:text-gray-500 max-w-md leading-relaxed">
        Specialized training programs and technical engagements beyond formal education.
      </p>
    </div>

    <div class="space-y-16">
      {EXPERIENCES.map((exp, idx) => (
        <div class="group relative pl-8 border-l border-gray-100 dark:border-zinc-800 hover:border-gray-300 dark:hover:border-zinc-600 transition-colors duration-300">

          <span class="absolute -left-[5px] top-0 w-2.5 h-2.5 rounded-full bg-white dark:bg-[#0d1117] border-2 border-gray-300 dark:border-zinc-700 group-hover:border-blue-500 transition-colors"></span>

          <div
            class="font-extrabold leading-none select-none pointer-events-none mb-4"
            style="font-size: clamp(60px, 10vw, 80px); color: transparent; -webkit-text-stroke: 1px rgba(150,150,150,0.15); letter-spacing: -0.04em; font-family: Inter, sans-serif;"
          >
            {exp.year}
          </div>

          <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-0.5">{exp.company}</h2>
          <p class="text-[11px] font-mono uppercase tracking-widest text-gray-400 dark:text-gray-600 mb-4">{exp.role}</p>

          <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-5 max-w-lg">
            {exp.desc}
          </p>

          <div class="bg-gray-50 dark:bg-zinc-900/80 border border-gray-100 dark:border-zinc-800 rounded-xl p-4 mb-5">
            <p class="text-[9px] font-mono uppercase tracking-[0.2em] text-gray-400 mb-2">Overview</p>
            <p class="text-xs text-gray-600 dark:text-gray-400 leading-relaxed">{exp.deepDive.overview}</p>
          </div>

          <div class="flex flex-wrap gap-1.5">
            {exp.deepDive.skills.map((s: string) => (
              <span class="px-2.5 py-0.5 rounded-full text-[9px] font-mono font-semibold border border-gray-200 dark:border-zinc-700 text-gray-500 dark:text-gray-500 bg-transparent">
                {s}
              </span>
            ))}
          </div>

        </div>
      ))}
    </div>

  </div>
</Layout>
